# ==========================================
# CURIOUSBEES V2 — GLOBAL APP CONFIGURATION
# ==========================================

# Node Environment (development | production | test)
NODE_ENV=development

# Core API service port
PORT=4000

# ==========================================
# DATABASE CONFIGURATION (PostgreSQL / Supabase)
# ==========================================
# Connection string for Prisma queries. Points to local Docker Postgres in development.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/srm_curiousbees_db?schema=public"

# Connection string for migrations (bypasses pgBouncer). Point to local Docker Postgres in development.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/srm_curiousbees_db?schema=public"

# ==========================================
# SUPABASE CLIENT CONFIGURATION
# ==========================================
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# ==========================================
# FIREBASE CLIENT CONFIGURATION
# ==========================================
NEXT_PUBLIC_FIREBASE_API_KEY="your-firebase-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-app-domain.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-app-bucket.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-messaging-sender-id"
NEXT_PUBLIC_FIREBASE_APP_ID="your-firebase-app-id"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="your-measurement-id"

# ==========================================
# FIREBASE ADMIN SDK CONFIGURATION
# ==========================================
# JSON credentials used by NestJS to verify bearer tokens and dispatch push notifications
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-fbsvc@your-project-id.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-escaped-private-key\n-----END PRIVATE KEY-----"

# ==========================================
# GEMINI API CONFIGURATION (AI Matching Engine)
# ==========================================
GEMINI_API_KEY="your-gemini-api-key"

# ==========================================
# REDIS CONFIGURATION (BullMQ Background Queues)
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ==========================================
# CORS & NETWORKING
# ==========================================
# Frontend client URL
FRONTEND_URL=http://localhost:3000

# Permitted origins for API requests (comma-separated list)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
