# ==========================================
# CURIOUSBEES V2 — GLOBAL CONFIGURATION TEMPLATE
# ==========================================

# Node Environment
NODE_ENV=development
PORT=4000

# DEVELOPMENT MODE BYPASS (Deprecated - Bypass is disabled)
DEVELOPMENT_MODE=false
NEXT_PUBLIC_DEVELOPMENT_MODE=false
AUTH_MODE=clerk
DEV_ROLE=RESEARCH_SCHOLAR
NEXT_PUBLIC_AUTH_MODE=clerk
NEXT_PUBLIC_DEV_ROLE=RESEARCH_SCHOLAR

# FRONTEND REST API CLIENT TARGET
NEXT_PUBLIC_API_URL=http://localhost:4000

# DATABASE CONNECTIONS (PostgreSQL / Supabase)
# Connection string for Prisma queries. Points to local Docker Postgres in development.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/srm_curiousbees_db?schema=public"

# Connection string for migrations (bypasses pgBouncer). Point to local Docker Postgres in development.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/srm_curiousbees_db?schema=public"

# SUPABASE KEYS
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# FIREBASE FCM CLIENT KEYS (Preserved for Push Notifications)
NEXT_PUBLIC_FIREBASE_API_KEY="your-firebase-api-key"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-messaging-sender-id"
NEXT_PUBLIC_FIREBASE_APP_ID="your-firebase-app-id"
NEXT_PUBLIC_FIREBASE_VAPID_KEY="your-fcm-vapid-key"

# FIREBASE FCM ADMIN SDK (Preserved for Backend Push Multicast Notifications)
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-fbsvc@your-project-id.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-escaped-private-key\n-----END PRIVATE KEY-----"

# CLERK AUTHENTICATION INFRASTRUCTURE
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_placeholder"
CLERK_SECRET_KEY="sk_test_placeholder"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# GEMINI API
GEMINI_API_KEY="your-gemini-api-key"

# REDIS CONFIG (Optional connection URL or Host/Port fallback)
REDIS_URL="redis://localhost:6379"
REDIS_HOST=localhost
REDIS_PORT=6379

# CORS & NETWORKING
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
