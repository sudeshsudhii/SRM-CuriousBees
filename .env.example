# ==========================================
# CURIOUSBEES V2 — GLOBAL CONFIGURATION TEMPLATE
# ==========================================

# Node Environment
NODE_ENV=development
PORT=4000


# FRONTEND REST API CLIENT TARGET
NEXT_PUBLIC_API_URL=http://localhost:4000

# DATABASE CONNECTIONS (PostgreSQL / Supabase)
# Connection string for Prisma queries. Points to local Docker Postgres in development.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/srm_curiousbees_db?schema=public"
# Connection string for migrations (bypasses pgBouncer). Point to local Docker Postgres in development.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/srm_curiousbees_db?schema=public"

# SUPABASE KEYS (Used for storage/public URL lookups)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# CLERK AUTHENTICATION INFRASTRUCTURE
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_placeholder"
CLERK_SECRET_KEY="sk_test_placeholder"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/"

# EMAIL ALERTS & NOTIFICATIONS (Resend API)
MAIN_ADMIN_EMAIL="admin@srmist.edu.in"
RESEND_API_KEY="re_placeholder"

# GEMINI API
GEMINI_API_KEY="your-gemini-api-key"

# REDIS CONFIG (Optional connection URL or Host/Port fallback)
REDIS_URL="redis://localhost:6379"
REDIS_HOST=localhost
REDIS_PORT=6379

# CORS & NETWORKING
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# Allowed Email Domains (comma-separated, e.g. srmist.edu.in,gmail.com)
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAINS="srmist.edu.in"
