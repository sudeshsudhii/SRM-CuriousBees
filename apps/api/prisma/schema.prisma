datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x", "linux-musl", "linux-musl-openssl-3.0.x"]
}

enum Role {
  RESEARCH_SUPERVISOR
  RESEARCH_SCHOLAR
  INSTITUTION_ADMIN
}

model User {
  id            String          @id @default(cuid())
  firebaseUid   String?         @unique
  name          String?
  email         String          @unique
  emailVerified DateTime?
  image         String?
  role          Role            @default(RESEARCH_SCHOLAR)
  department    String?
  bio           String?
  approved      Boolean         @default(false)
  supervisorId  String?
  supervisorEmail String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  accounts      Account[]
  sessions      Session[]
  interests     UserInterest[]
  threads       Thread[]
  comments      Comment[]
  opportunities Opportunity[]
  notificationTokens NotificationToken[]
  notifications Notification[]
  preferences   UserPreference?
  recommendationEngagements RecommendationEngagement[]
  copilotChatSessions CopilotChatSession[]
  
  // Supervisor/Scholar mappings
  supervisor    User?           @relation("SupervisorToScholar", fields: [supervisorId], references: [id])
  scholars      User[]          @relation("SupervisorToScholar")
  
  // Collaboration and Workspace relations
  collaborationRequests CollaborationRequest[]
  workspaceMembers      WorkspaceMember[]
  workspaceAnnouncements WorkspaceAnnouncement[]
  workspaceFiles        WorkspaceFile[]
}

// NextAuth v5 standard tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// SRM_Recollab Custom MVP Models
model ResearchInterest {
  id    String         @id @default(cuid())
  name  String         @unique
  users UserInterest[]
}

model UserInterest {
  userId     String
  interestId String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  interest   ResearchInterest @relation(fields: [interestId], references: [id], onDelete: Cascade)

  @@id([userId, interestId])
}

model Thread {
  id        String    @id @default(cuid())
  title     String
  content   String    @db.Text
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  tags      String[]
  comments  Comment[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  threadId  String
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Opportunity {
  id             String   @id @default(cuid())
  title          String
  description    String   @db.Text
  department     String
  researchDomain String
  authorId       String
  author         User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  collaborationRequests CollaborationRequest[]
}

enum ApprovalStatus {
  PENDING
  PUBLISHED
  REJECTED
  NEEDS_INFO
}

enum ProcessingStatus {
  PENDING
  FILTERED
  QUEUED
  PROCESSING
  AI_PROCESSING
  EXTRACTED
  IGNORED
  FAILED
  SUCCESS
}

enum EventStatus {
  DRAFT
  PUBLISHED
  REVIEW_REQUIRED
  FAILED
}

enum EventPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Event {
  id                String         @id @default(cuid())
  title             String
  eventType         String
  speaker           String?
  department        String?
  date              DateTime
  time              String
  venue             String
  topic             String?
  organizerEmail    String?
  confidence        Float
  aiModel           String
  aiProvider        String
  rawEmail          String?        @db.Text
  status            EventStatus
  priority          EventPriority  @default(MEDIUM)

  // Kept from previous iterations
  description       String?        @db.Text
  category          String?
  posterUrl         String?
  registrationLink  String?
  tags              String[]
  embedding         Unsupported("vector(768)")?

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  notifications     Notification[]
  clusterMembers    EventClusterMember[]
  recommendationEngagements RecommendationEngagement[]
  engagementScore   EngagementScore?
}

model Notification {
  id            String   @id @default(cuid())
  userId        String
  eventId       String?
  title         String
  body          String
  sentStatus    Boolean  @default(false)
  openedStatus  Boolean  @default(false)
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event         Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)

  createdAt     DateTime @default(now())
}

model NotificationLog {
  id            String   @id @default(cuid())
  eventId       String
  recipientType String
  channel       String
  status        String
  sentAt        DateTime @default(now())
}

model UserPreference {
  id                   String   @id @default(cuid())
  userId               String   @unique
  department           String?
  eventType            String?
  tags                 String[]
  notificationsEnabled Boolean  @default(true)
  createdAt            DateTime @default(now())
  
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AIProcessingLog {
  id               String           @id @default(cuid())
  gmailMessageId   String           @unique
  senderEmail      String
  subject          String
  rawEmailBody     String           @db.Text
  extractedJson    Json?
  confidenceScore  Float?
  status           ProcessingStatus @default(PENDING)
  errorReason      String?          @db.Text
  retryCount       Int              @default(0)

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model GmailCredentials {
  id           String   @id @default("singleton")
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime
  updatedAt    DateTime @updatedAt
}

model SearchAnalytics {
  id           String   @id @default(cuid())
  query        String
  userId       String?
  resultCount  Int      @default(0)
  topScore     Float?
  filters      Json?
  createdAt    DateTime @default(now())
}

model AggregatedMetric {
  id          String   @id @default(cuid())
  metricName  String   // e.g. "total_events", "department_activity", "notification_engagement"
  metricValue Float
  dimensions  Json?    // e.g. { "department": "Mechanical", "month": "2026-05" }
  timestamp   DateTime @default(now())

  @@index([metricName, timestamp])
}

model AIObservabilityLog {
  id            String   @id @default(cuid())
  operationName String   // e.g. "slm_extraction", "embedding_generation", "semantic_search"
  latencyMs     Float
  status        String   // "SUCCESS" | "FAILED"
  errorMessage  String?  @db.Text
  retryCount    Int      @default(0)
  metadata      Json?    // e.g. { "model": "qwen2.5:7b", "cpuUsage": 12.4 }
  createdAt     DateTime @default(now())

  @@index([operationName, createdAt])
}

model EventCluster {
  id              String               @id @default(cuid())
  name            String               // e.g. "AI & Machine Learning Research"
  description     String?              @db.Text
  centerEmbedding Unsupported("vector(768)")?
  department      String?
  eventCount      Int                  @default(0)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  members         EventClusterMember[]

  @@index([name])
}

model EventClusterMember {
  clusterId  String
  eventId    String
  similarity Float
  cluster    EventCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  event      Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([clusterId, eventId])
}

model RecommendationEngagement {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  action    String   // "VIEW" | "CLICK" | "DISMISS"
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([userId, eventId])
}

model EngagementScore {
  id              String   @id @default(cuid())
  eventId         String   @unique
  popularityScore Float    @default(0.0) // Clicks, notifications, opens weighted
  openRate        Float    @default(0.0)
  predictionScore Float    @default(0.0) // Attendance estimation
  engagementRank  Int?
  updatedAt       DateTime @updatedAt
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model HistoricalMetric {
  id           String   @id @default(cuid())
  metricGroup  String   // e.g. "departmental_engagement", "ai_system_health"
  metricName   String
  metricValue  Float
  dimensions   Json?
  aggregatedAt DateTime
  createdAt    DateTime @default(now())

  @@index([metricGroup, metricName, aggregatedAt])
}

model ArchivedEventEmbedding {
  id         String   @id
  eventId    String
  embedding  Unsupported("vector(768)")
  archivedAt DateTime @default(now())
}

model CopilotChatSession {
  id        String           @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  messages  CopilotMessage[]
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CopilotMessage {
  id            String             @id @default(cuid())
  sessionId     String
  role          String             // "USER" | "ASSISTANT"
  content       String             @db.Text
  citations     Json?              // Mapped list of referenced event metadata
  telemetry     Json?              // Latency, model config, token count
  createdAt     DateTime           @default(now())
  session       CopilotChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model CollaborationRequest {
  id             String         @id @default(cuid())
  scholarId      String
  opportunityId  String
  status         ApprovalStatus @default(PENDING)
  message        String?        @db.Text
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  scholar        User           @relation(fields: [scholarId], references: [id], onDelete: Cascade)
  opportunity    Opportunity    @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([scholarId, opportunityId])
}

model Workspace {
  id            String                  @id @default(cuid())
  title         String
  description   String?                 @db.Text
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  members       WorkspaceMember[]
  files         WorkspaceFile[]
  milestones    WorkspaceMilestone[]
  announcements WorkspaceAnnouncement[]
}

model WorkspaceMember {
  workspaceId   String
  userId        String
  role          String                  @default("MEMBER") // "OWNER" | "MEMBER"
  joinedAt      DateTime                @default(now())

  workspace     Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
}

model WorkspaceFile {
  id            String                  @id @default(cuid())
  workspaceId   String
  name          String
  url           String
  size          Int                     @default(0)
  uploadedById  String
  uploadedAt    DateTime                @default(now())

  workspace     Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  uploadedBy    User                    @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
}

model WorkspaceMilestone {
  id            String                  @id @default(cuid())
  workspaceId   String
  title         String
  description   String?                 @db.Text
  dueDate       DateTime?
  completed     Boolean                 @default(false)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  workspace     Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model WorkspaceAnnouncement {
  id            String                  @id @default(cuid())
  workspaceId   String
  title         String
  content       String                  @db.Text
  authorId      String
  createdAt     DateTime                @default(now())

  workspace     Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author        User                    @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id            String   @id @default(cuid())
  userId        String?
  action        String   // e.g. "APPROVE_SCHOLAR", "DELETE_POST", "WORKSPACE_CREATE"
  details       String?  @db.Text
  ipAddress     String?
  createdAt     DateTime @default(now())
}

model NotificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
