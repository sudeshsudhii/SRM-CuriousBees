# ==========================================
# CURIOUSBEES V2 — FRONTEND CONFIGURATION
# ==========================================

# Target URL for NestJS backend REST API
NEXT_PUBLIC_API_URL=http://localhost:4000

# Development Mode Auth Bypass Override
# Set to 'true' to completely disable Firebase login, onboarding checks, 
# and redirects, allowing instant access to all dashboards with a mock user.
NEXT_PUBLIC_DEVELOPMENT_MODE=true

# ==========================================
# SUPABASE CONFIGURATION
# ==========================================
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"

# ==========================================
# FIREBASE CLIENT CONFIGURATION
# ==========================================
NEXT_PUBLIC_FIREBASE_API_KEY="your-firebase-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-app-domain.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-app-bucket.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-messaging-sender-id"
NEXT_PUBLIC_FIREBASE_APP_ID="your-firebase-app-id"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="your-measurement-id"

# Firebase Cloud Messaging VAPID key for web push notifications
NEXT_PUBLIC_FIREBASE_VAPID_KEY="your-fcm-vapid-key"
